{
  "name": "spaced-repetition-server",
  "version": "1.0.0",
  "description": "Spaced Repetition Backend for Professional Engineer Exam Prep",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:backup": "node -e \"import('./backupManager.js').then(m => m.runBackup())\"",
    "db:restore": "node restore.js",
    "sync-standards": "node scratch/sync_standards_from_prod.mjs",
    "update-db-standards": "node update_db_generation_standards.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "@vercel/blob": "^2.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "katex": "^0.17.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
